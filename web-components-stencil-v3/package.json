{
  "name": "web-components",
  "version": "0.0.1",
  "description": "Example how to use TON Design System web-components",
  "main": "dist/index.cjs.js",
  "module": "./dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/web-components/web-components.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "NODE_ENV=production run-s clean build:tailwind build:stencil",
    "start": "NODE_ENV=development npm-run-all clean -p dev:*",
    "clean": "rm -rf www",
    "dev:stencil": "stencil build --dev --watch --serve",
    "dev:tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./src/components/main-app/assets/tailwind.css --watch",
    "build:stencil": "stencil build --docs",
    "build:tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./www/tailwind.css --minify",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@designervoid/ton-design-system": "^1.0.19",
    "@stencil/core": "^3.2.0",
    "tailwindest": "^1.0.5"
  },
  "license": "MIT",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@stencil/postcss": "^2.1.0",
    "@stencil/sass": "^2.0.0",
    "@types/jest": "^27.0.3",
    "autoprefixer": "^10.4.13",
    "cssnano": "^5.1.15",
    "jest": "^27.0.3",
    "jest-cli": "^27.4.5",
    "npm-run-all": "^4.1.5",
    "puppeteer": "^19.8.0",
    "stencil-tailwind-plugin": "^1.7.0",
    "tailwindcss": "^3.2.4",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.3"
  }
}
